[Unit]
Description=PVE-Sleep Boot Configuration
Documentation=https://github.com/kryxan/pve-sleep
After=multi-user.target
Wants=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/sleep-boot.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
